# PostgreSQL / Neon database connection string
# Use the standard Postgres connection string format, not the Neon REST API endpoint.
# Get this from your Neon dashboard → Connection Details → Connection string
DATABASE_URL=postgresql://username:password@hostname-pooler.region.aws.neon.tech/dbname?sslmode=require&channel_binding=require

# Clerk JWKS URL for verifying tokens
# Get from: Clerk Dashboard → your app → API Keys → Advanced → JWKS URL
# Dev:  https://your-instance.clerk.accounts.dev/.well-known/jwks.json
# Prod: https://your-instance.clerk.accounts.com/.well-known/jwks.json
CLERK_JWKS_URL=https://your-instance.clerk.accounts.com/.well-known/jwks.json

# Clerk publishable key (frontend — also kept here for reference)
# Dev starts with pk_test_, Prod starts with pk_live_
CLERK_API_KEY=pk_live_your_publishable_key_here

# Clerk secret key for server-side Clerk API calls (user management, invites)
# Dev starts with sk_test_, Prod starts with sk_live_
CLERK_API_SECRET=sk_live_your_secret_key_here

# Encryption key used to secure stored passwords in the database.
# Use a strong 32-byte key and keep it secret.
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<run-the-command-above-and-paste-here>

# Gemini API key for AI-driven chart generation (fallback if no AI model configured in DB)
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS_ORIGINS is no longer used — CORS is open to all origins.
# Security is enforced by Clerk JWT validation on every authenticated endpoint.
CORS_ORIGINS=
