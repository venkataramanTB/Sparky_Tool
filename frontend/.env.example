# ── Clerk authentication ───────────────────────────────────────────────────────
# Get this from https://dashboard.clerk.com → your app → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# ── API routing ────────────────────────────────────────────────────────────────
# VITE_API_URL — backend origin exposed to the browser bundle.
#   LOCAL DEV  → leave empty (Vite dev-server proxy forwards /api → BACKEND_URL)
#   VERCEL     → set to your Render backend URL, e.g. https://sparky-tool.onrender.com
VITE_API_URL=

# BACKEND_URL — dev proxy target (used only by vite.config.js, never in the browser).
#   Change this if your local FastAPI backend runs on a different port.
BACKEND_URL=http://localhost:8000
